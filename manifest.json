{
  "manifest_version": 3,
  "name": "帰ってきたDarkBlueテーマ(X)",
  "version": "1.0.41",
  "description": "X（旧Twitter）のダークテーマ(黒)を、かつて存在したDarkBlue(Dim)テーマに変換するChrome拡張機能",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "css": ["src/styles/darkblue.css"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ]
}
